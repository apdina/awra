# Convex
NEXT_PUBLIC_CONVEX_URL=your_convex_url_here
CONVEX_DEPLOYMENT=your_deployment_here
CONVEX_DEPLOY_KEY=your_convex_deploy_key_here

# JWT Secret (REQUIRED - Generate a strong random secret)
# Generate with: openssl rand -base64 32
JWT_SECRET=your_secure_jwt_secret_here_change_this_in_production

# App URL (Required for email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (Optional - for Google Sign-In)
# Get from: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Facebook OAuth (Optional - for Facebook Sign-In)
NEXT_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id_here

# Email Service (Choose one: resend, sendgrid, smtp)
EMAIL_PROVIDER=resend
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Your App Name

# Resend (Recommended - easiest setup)
# Sign up at https://resend.com (100 emails/day free)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# SendGrid (Alternative)
# Sign up at https://sendgrid.com (100 emails/day free)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# SMTP (Alternative - requires nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Redis (REQUIRED for production caching)
# Get free Redis from Upstash: https://upstash.com (10k commands/day free)
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-rest-url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Payment Providers
# Skrill support has been removed from this example

# Admin Setup (One-time use for creating first admin user)
# Generate with: openssl rand -base64 32
ADMIN_SETUP_SECRET=your_admin_setup_secret_here_change_this

# Admin Secret (REQUIRED for admin operations like system messages)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=your_secure_admin_secret_min_32_chars_change_this

# CSRF Token Secret (REQUIRED for CSRF protection)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_TOKEN_SECRET=your_csrf_secret_min_32_chars_change_this

# Generate with: openssl rand -base64 32
INTERNAL_SECRET=your-internal-secret-here-change-this-in-production